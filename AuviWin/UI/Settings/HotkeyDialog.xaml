<Window x:Class="AuviWin.UI.Settings.HotkeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Press a Hotkey" Height="140" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16" VerticalAlignment="Center">
        <TextBlock Text="Press the hotkey combination you want to use." 
                   TextWrapping="Wrap" Margin="0,0,0,12"/>
        <TextBox x:Name="HotkeyBox" IsReadOnly="True" FontSize="14"
                 HorizontalContentAlignment="Center"
                 Text="Waiting for key press…"
                 KeyDown="HotkeyBox_KeyDown"
                 PreviewKeyDown="HotkeyBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="64" IsDefault="True" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="64" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
